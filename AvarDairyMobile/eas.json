{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview-customer": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "customer",
        "EXPO_PUBLIC_APP_VARIANT": "customer"
      }
    },

    "preview-admin": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "admin",
        "EXPO_PUBLIC_APP_VARIANT": "admin"
      }
    },
    "production": {
      "env": {
        "APP_VARIANT": "customer",
        "EXPO_PUBLIC_APP_VARIANT": "customer"
      }
    }
  }
}
